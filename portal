}

/* =====================================================================
   FIELD VALUE RESOLUTION
   ===================================================================== */
function resolveFieldValue(inv, key){
  switch(key){
    case 'docTitleAr':   return inv.type === 'فاتورة' ? 'فاتورة' : 'عرض سعر';
    case 'docTitleEn':   return inv.type === 'فاتورة' ? 'Invoice' : 'Price offer';
    case 'client':       return inv.client || '';
    case 'firstParty':   return inv.firstParty || '';
    case 'project':      return inv.project || '';
    case 'projectType':  return inv.projectType || '';
    case 'date':         return fmtDate(inv.date);
    case 'docNumber':    return inv.docNumber || '';
    case 'docNumberEn':  return 'Doc ID ' + (inv.docNumber || '');
    case 'price':        return fmtMoney(inv.price);
    case 'currency':     return currencySymbol(inv.currency);
    case 'items':        return (inv.items || '').split('\n').map(l=>l.trim()).filter(Boolean).map(l=>'• '+l).join('\n');
    case 'bankName':     return inv.bankName || '';
    case 'account':      return inv.account || '';
    case 'notes':        return inv.notes || '';
    case 'qrcode':       return inv.account || inv.docNumber || '';
    default:             return '';
  }
}

/* =====================================================================
   PDF EXPORT
   ===================================================================== */
async function renderTemplatePageCanvas(tpl, inv, isMain){
  const renderW = isMain ? tpl.bgWidth : (tpl.termsWidth || tpl.bgWidth);
  const renderH = isMain ? tpl.bgHeight : (tpl.termsHeight || tpl.bgHeight);
  const bgUrl = isMain ? tpl.bgDataUrl : tpl.termsBgDataUrl;
  const scale = renderW / (tpl.displayWidth || renderW);

  const stage = document.createElement('div');
  stage.style.cssText = `position:relative;width:${renderW}px;height:${renderH}px;background:#fff;font-family:'IBM Plex Sans Arabic',sans-serif`;

  const img = document.createElement('img');
  img.src = bgUrl;
  img.style.cssText = `position:absolute;top:0;left:0;width:${renderW}px;height:${renderH}px;display:block`;
  stage.appendChild(img);

  await new Promise((res, rej) => {
    if(img.complete && img.naturalHeight){ res(); return; }
    img.onload = res;
    img.onerror = rej;
  });

  // Only main page gets fields - terms page is bare
  if(isMain){
    for(const f of (tpl.fields || [])){
      const value = resolveFieldValue(inv, f.key);
      const meta = FIELD_MAP[f.key] || {};
      const x = f.x * scale;
      const y = f.y * scale;
      const w = f.w * scale;
      const h = f.h * scale;
      const fontSize = (f.size || 14) * scale;
      const lineHeight = f.lineHeight ?? 1.4;
      const letterSpacing = (f.letterSpacing ?? 0) * scale;
      const isQR = f.kind === 'qr';
      const isPreserve = f.preserve || !!meta.preserve;

      // Vertical alignment via padding-top
      const valign = f.valign || 'center';
      let paddingTop = 0;
      if(!isQR){
        const textH = fontSize * lineHeight;
        if(valign === 'center') paddingTop = Math.max(0, (h - textH) / 2);
        else if(valign === 'bottom') paddingTop = Math.max(0, h - textH);
        else paddingTop = 0; // top
      }

      const node = document.createElement('div');

      if(isQR){
        node.className = 'render-text qr-host';
        node.style.cssText =
          `position:absolute;` +
          `left:${x}px;top:${y}px;width:${w}px;height:${h}px;` +
          `background:white;display:flex;align-items:center;justify-content:center;`;
        const qrDiv = document.createElement('div');
        node.appendChild(qrDiv);
        try{
          new QRCode(qrDiv, {
            text: value || ' ',
            width: Math.max(60, Math.min(w, h) - 4),
            height: Math.max(60, Math.min(w, h) - 4),
            colorDark: f.color || '#000000',
            colorLight: '#ffffff',
            correctLevel: QRCode.CorrectLevel.M,
          });
        }catch(e){}
      } else {
        node.className = 'render-text' + (isPreserve ? ' preserve' : '');
        // text-align controls horizontal — no flex needed
        node.style.cssText =
          `position:absolute;` +
          `left:${x}px;top:${y}px;width:${w}px;height:${h}px;` +
          `padding-top:${paddingTop}px;` +
          `font-size:${fontSize}px;font-weight:${f.weight || 500};` +
          `color:${f.color || '#1a1a1a'};` +
          `direction:${f.dir || 'rtl'};` +
          `text-align:${f.align || 'right'};` +
          `line-height:${lineHeight};` +
          `letter-spacing:${letterSpacing}px;` +
          `font-family:'IBM Plex Sans Arabic',sans-serif;` +
          `overflow:hidden;box-sizing:border-box;` +
          (isPreserve ? 'white-space:pre-wrap;' : 'white-space:nowrap;');
        node.textContent = value;
      }

      stage.appendChild(node);
    }
  }

  return { stage, renderW, renderH };
}

async function exportInvoice(inv, templateId){
  const tpl = state.templates[templateId];
  if(!tpl){ toast('النموذج غير موجود','error'); return; }

  const exportBtn = $('#export-btn');
  const originalHTML = exportBtn?.innerHTML;
  if(exportBtn){ exportBtn.disabled = true; exportBtn.innerHTML = '<span class="loader"></span> جاري التصدير...'; }

  const host = $('#render-host');
  host.innerHTML = '';

  try {
    // Build pages
    const pageDefs = [
      await renderTemplatePageCanvas(tpl, inv, true),
    ];
    if(tpl.termsBgDataUrl){
      pageDefs.push(await renderTemplatePageCanvas(tpl, inv, false));
    }

    // Append all stages to host so html2canvas can capture
    for(const p of pageDefs) host.appendChild(p.stage);

    // wait fonts + a tick
    try{ await document.fonts.ready; }catch{}
    await new Promise(r => setTimeout(r, 300));

    const { jsPDF } = window.jspdf;
    // Use orientation of the first page
    const first = pageDefs[0];
    const isLandscape = first.renderW > first.renderH;
    const pdf = new jsPDF({
      orientation: isLandscape ? 'landscape' : 'portrait',
      unit: 'mm',
      format: 'a4',
      compress: true,
    });
    const pdfW = isLandscape ? 297 : 210;
    const pdfH = isLandscape ? 210 : 297;

    for(let i = 0; i < pageDefs.length; i++){
      const p = pageDefs[i];
      const canvas = await html2canvas(p.stage, {
        backgroundColor: '#ffffff',
        useCORS: true,
        logging: false,
        scale: 2,
        width: p.renderW,
        height: p.renderH,
      });
      const imgRatio = p.renderW / p.renderH;
      const pdfRatio = pdfW / pdfH;
      let drawW, drawH;
      if(imgRatio > pdfRatio){
        drawW = pdfW; drawH = pdfW / imgRatio;
      } else {
        drawH = pdfH; drawW = pdfH * imgRatio;
      }
      const ox = (pdfW - drawW) / 2;
      const oy = (pdfH - drawH) / 2;

      if(i > 0) pdf.addPage('a4', isLandscape ? 'landscape' : 'portrait');
      pdf.addImage(canvas.toDataURL('image/jpeg', 0.95), 'JPEG', ox, oy, drawW, drawH);
    }

    const fname = `${inv.type||'invoice'}-${inv.client||''}-${inv.docNumber||''}.pdf`.replace(/[\/\\?%*:|"<>]/g,'-');
    pdf.save(fname);
    toast('تم تصدير PDF','success');
  } catch(err){
    console.error(err);
    toast('تعذر التصدير: '+(err.message||'خطأ'),'error');
  } finally {
    host.innerHTML = '';
    if(exportBtn){ exportBtn.disabled = false; exportBtn.innerHTML = originalHTML; }
  }
}

