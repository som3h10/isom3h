function buildStage(){
  // Compute display size - keep aspect ratio, fit a max width of ~720px
  const stageHost = $('#stage-host');
  stageHost.innerHTML = '';
  const MAX_W = 720;
  let dw = state.builder.bgWidth, dh = state.builder.bgHeight;
  if(dw > MAX_W){
    const r = MAX_W / dw;
    dw = MAX_W;
    dh = Math.round(state.builder.bgHeight * r);
  }
  state.builder.displayWidth = dw;
  state.builder.displayHeight = dh;

  const stage = document.createElement('div');
  stage.className = 'stage';
  stage.id = 'builder-stage';
  stage.style.cssText = `width:${dw}px;height:${dh}px`;
  const img = document.createElement('img');
  img.src = state.builder.bgDataUrl;
  img.style.cssText = `width:${dw}px;height:${dh}px;display:block`;
  stage.appendChild(img);

  // click on stage = place armed field
  stage.addEventListener('click', e => {
    if(!state.builder.armedKey) return;
    if(e.target.closest('.field-box')) return;
    const rect = stage.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    placeField(state.builder.armedKey, x, y);
  });

  stageHost.appendChild(stage);
  renderFieldBoxes();
}

function renderChips(){
  const host = $('#chips');
  host.innerHTML = '';
  let placed = 0;
  for(const f of FIELDS){
    const isPlaced = state.builder.fields.some(x => x.key === f.key);
    if(isPlaced) placed++;
    const btn = document.createElement('button');
    btn.className = 'chip' + (isPlaced ? ' placed' : '') + (state.builder.armedKey === f.key ? ' armed' : '');
    btn.textContent = f.label;
    btn.addEventListener('click', () => {
      state.builder.armedKey = (state.builder.armedKey === f.key) ? null : f.key;
      renderChips();
      $('#builder-stage')?.classList.toggle('placing', !!state.builder.armedKey);
    });
    host.appendChild(btn);
  }
  $('#fields-count').textContent = `${placed}/${FIELDS.length}`;
}

function placeField(key, x, y){
  // remove existing field with same key (one per template per key)
  state.builder.fields = state.builder.fields.filter(f => f.key !== key);
  const meta = FIELD_MAP[key];
  const isQR = meta.kind === 'qr';
  const w = isQR ? 100 : 200;
  const h = isQR ? 100 : Math.max(28, (meta.size||14) * 1.5);
  const fld = {
    fid: uid('f'),
    key,
    x: Math.max(0, x - w/2),
    y: Math.max(0, y - h/2),
    w, h,
    align: meta.dir === 'ltr' ? 'left' : 'right',
    dir: meta.dir,
    size: meta.size,
    weight: meta.weight,
    color: '#1a1a1a',
    kind: meta.kind || 'text',
    preserve: !!meta.preserve,
  };
  state.builder.fields.push(fld);
  state.builder.armedKey = null;
  state.builder.selectedFid = fld.fid;
  $('#builder-stage')?.classList.remove('placing');
  renderChips();
  renderFieldBoxes();
  renderProps();
}

function renderFieldBoxes(){
  const stage = $('#builder-stage');
  if(!stage) return;
  $$('.field-box', stage).forEach(n => n.remove());
  for(const f of state.builder.fields){
    const meta = FIELD_MAP[f.key];
    const valign = f.valign || 'center';
    const alignItems = valign === 'top' ? 'flex-start' : (valign === 'bottom' ? 'flex-end' : 'center');
    const div = document.createElement('div');
    div.className = 'field-box' + 
                    (f.kind === 'qr' ? ' is-qr' : '') +
                    (state.builder.selectedFid === f.fid ? ' selected' : '');
    div.style.cssText = `left:${f.x}px;top:${f.y}px;width:${f.w}px;height:${f.h}px;` +
                        `direction:${f.dir};text-align:${f.align};` +
                        `justify-content:${f.align==='center'?'center':(f.align==='left'?'flex-start':'flex-end')};` +
                        `align-items:${alignItems};`;
    div.dataset.fid = f.fid;
    div.innerHTML = `<span class="lbl">${escapeHTML(meta?.label || f.key)}</span>
                     <span class="resize-handle"></span>
                     <span class="x-btn">×</span>`;
    div.addEventListener('mousedown', e => onFieldMouseDown(e, f.fid));
    div.addEventListener('touchstart', e => onFieldMouseDown(e, f.fid), {passive:false});
    stage.appendChild(div);
  }
}

function onFieldMouseDown(e, fid){
  const target = e.target;
  // X button
  if(target.classList.contains('x-btn')){
    e.preventDefault(); e.stopPropagation();
    state.builder.fields = state.builder.fields.filter(f => f.fid !== fid);
    if(state.builder.selectedFid === fid) state.builder.selectedFid = null;
    renderChips();
    renderFieldBoxes();
    renderProps();
    return;
  }

  e.preventDefault(); e.stopPropagation();
  state.builder.selectedFid = fid;
  renderFieldBoxes();
  renderProps();

  const fld = state.builder.fields.find(f => f.fid === fid);
  if(!fld) return;

  const isResize = target.classList.contains('resize-handle');
  const stage = $('#builder-stage');

  const point = e.touches ? e.touches[0] : e;
  const startX = point.clientX, startY = point.clientY;
  const orig = { x: fld.x, y: fld.y, w: fld.w, h: fld.h };

  const onMove = (ev) => {
    const p = ev.touches ? ev.touches[0] : ev;
    const dx = p.clientX - startX;
    const dy = p.clientY - startY;
    if(isResize){
      fld.w = Math.max(30, Math.min(state.builder.displayWidth - fld.x, orig.w + dx));
      fld.h = Math.max(20, Math.min(state.builder.displayHeight - fld.y, orig.h + dy));
    } else {
      fld.x = Math.max(0, Math.min(state.builder.displayWidth - fld.w, orig.x + dx));
      fld.y = Math.max(0, Math.min(state.builder.displayHeight - fld.h, orig.y + dy));
    }
    renderFieldBoxes();
    renderProps();
  };
  const onUp = () => {
    document.removeEventListener('mousemove', onMove);
    document.removeEventListener('mouseup', onUp);
    document.removeEventListener('touchmove', onMove);
    document.removeEventListener('touchend', onUp);
  };
  document.addEventListener('mousemove', onMove);
  document.addEventListener('mouseup', onUp);
  document.addEventListener('touchmove', onMove, {passive:false});
  document.addEventListener('touchend', onUp);
}

// Common color swatches for invoice design
const COLOR_SWATCHES = [
  '#000000','#1a1a1a','#4a4a4a','#8b8680',
  '#ffffff','#f5f3ef','#e6e2da',
  '#c9a96e','#d4af37','#b8860b',
