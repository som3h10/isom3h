function setSegValue(segId, val){
  const seg = $('#'+segId);
  if(!seg) return;
  $$('button', seg).forEach(b => b.classList.toggle('on', b.dataset.val === val));
}

function renderProps(){
  if(!state.builder.selectedFid){
    $('#props-empty').hidden = false;
    $('#props-form').hidden = true;
    return;
  }
  const fld = state.builder.fields.find(f => f.fid === state.builder.selectedFid);
  if(!fld){
    $('#props-empty').hidden = false;
    $('#props-form').hidden = true;
    return;
  }
  $('#props-empty').hidden = true;
  $('#props-form').hidden = false;

  // defaults for new properties
  fld.dir = fld.dir || (FIELD_MAP[fld.key]?.dir || 'rtl');
  fld.valign = fld.valign || 'center';
  fld.lineHeight = fld.lineHeight ?? 1.4;
  fld.letterSpacing = fld.letterSpacing ?? 0;

  setSegValue('p-dir-seg', fld.dir);
  setSegValue('p-align-seg', fld.align);
  setSegValue('p-valign-seg', fld.valign);

  $('#p-size').value = Math.round(fld.size);
  $('#p-weight').value = fld.weight;
  $('#p-color').value = fld.color;
  $('#p-color-hex').value = (fld.color||'').toUpperCase();
  $('#p-lineHeight').value = fld.lineHeight;
  $('#p-letterSpacing').value = fld.letterSpacing;
  $('#p-x').value = Math.round(fld.x);
  $('#p-y').value = Math.round(fld.y);
  $('#p-w').value = Math.round(fld.w);
  $('#p-h').value = Math.round(fld.h);

