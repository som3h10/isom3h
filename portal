    <div class="card" style="max-width:600px;margin-top:12px">
      <div style="font-size:0.7rem;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--line)">تحميل ملف الـ API</div>
      <p style="font-size:0.82rem;color:var(--muted);margin-bottom:14px;line-height:1.7">حمّل ملف PHP وارفعه على سيرفر WordPress في المسار:<br>
      <code style="background:var(--bg);padding:4px 8px;border-radius:4px;font-size:0.78rem;direction:ltr;display:inline-block;margin-top:4px">wp-content/uploads/invoices-app/invoices-api.php</code></p>
      <button class="btn btn-primary" onclick="downloadApiFile()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        تحميل invoices-api.php
      </button>
    </div>
  </section>

<div id="render-host" style="position:fixed;left:-99999px;top:0;background:white"></div>

<div class="toast" id="toast"></div>

<script>
"use strict";

/* =====================================================================
   STATE & STORAGE
   ===================================================================== */
const KEYS = {
  templates: 'inv_templates_v2',
  invoices:  'inv_invoices_v2',
  active:    'inv_active_template_v2',
  apiUrl:    'inv_api_url',
  apiKey:    'inv_api_key',
};

const FIELDS = [
  // key, label, default font size, default direction, sample value getter
  { key:'docTitleAr',    label:'عنوان (عربي)',     size:48, dir:'rtl', weight:'800' },
  { key:'docTitleEn',    label:'عنوان (إنجليزي)',  size:30, dir:'ltr', weight:'500' },
  { key:'client',        label:'اسم العميل',        size:14, dir:'rtl', weight:'700' },
  { key:'firstParty',    label:'الطرف الأول',       size:14, dir:'rtl', weight:'700' },
  { key:'project',       label:'اسم المشروع',       size:14, dir:'rtl', weight:'700' },
  { key:'projectType',   label:'نوع المشروع',       size:13, dir:'rtl', weight:'500' },
  { key:'date',          label:'التاريخ',           size:14, dir:'ltr', weight:'500' },
  { key:'docNumber',     label:'رقم الوثيقة',      size:12, dir:'ltr', weight:'500' },
  { key:'docNumberEn',   label:'رقم (إنجليزي)',    size:11, dir:'ltr', weight:'500' },
  { key:'price',         label:'السعر',             size:24, dir:'ltr', weight:'800' },
  { key:'currency',      label:'العملة',            size:18, dir:'rtl', weight:'500' },
  { key:'items',         label:'بنود المشروع',     size:13, dir:'rtl', weight:'400', preserve:true },
  { key:'bankName',      label:'اسم البنك',         size:13, dir:'rtl', weight:'500' },
  { key:'account',       label:'رقم الحساب',        size:12, dir:'ltr', weight:'500' },
  { key:'notes',         label:'ملاحظات',           size:12, dir:'rtl', weight:'400', preserve:true },
  { key:'qrcode',        label:'باركود QR',         size:14, dir:'ltr', weight:'400', kind:'qr' },
];

const FIELD_MAP = Object.fromEntries(FIELDS.map(f => [f.key, f]));

/* =====================================================================
   LOCAL CACHE (localStorage fallback + offline support)
   ===================================================================== */
const cache = {
  get(k){ try{ return JSON.parse(localStorage.getItem(k)); }catch{ return null; } },
  set(k,v){ try{ localStorage.setItem(k, JSON.stringify(v)); }catch{} },
};
// backward compat
const store = cache;

/* =====================================================================
   API CONFIG
   ===================================================================== */
const apiConfig = {
  get url(){ return cache.get(KEYS.apiUrl) || '' },
  get key(){ return cache.get(KEYS.apiKey) || '' },
  get ready(){ return !!(this.url && this.key) },
};

/* =====================================================================
   API CALLS
   ===================================================================== */
async function apiCall(action, body=null, extra={}){
  if(!apiConfig.ready) throw new Error('API غير مضبوط');
  const url = new URL(apiConfig.url);
  url.searchParams.set('action', action);
  Object.entries(extra).forEach(([k,v])=>url.searchParams.set(k,v));
  const opts = { method: body?'POST':'GET', headers:{'Content-Type':'application/json','X-Api-Key':apiConfig.key} };
  if(body) opts.body = JSON.stringify(body);
  const res = await fetch(url.toString(), opts);
  if(!res.ok) throw new Error('HTTP '+res.status);
  const j = await res.json();
  if(!j.ok && j.error) throw new Error(j.error);
  return j;
}

/* =====================================================================
   DATA LAYER
   ===================================================================== */
const db = {
  async getInvoices(){
    if(!apiConfig.ready) return cache.get(KEYS.invoices)||[];
    try{ const r=await apiCall('get_invoices'); cache.set(KEYS.invoices,r.data||[]); return r.data||[]; }
    catch(e){ return cache.get(KEYS.invoices)||[]; }
  },
  async saveInvoice(inv){
    cache.set(KEYS.invoices, state.invoices);
    if(!apiConfig.ready) return true;
    try{ await apiCall('save_invoice',inv); return true; }catch(e){ return false; }
  },
  async deleteInvoice(id){
    cache.set(KEYS.invoices, state.invoices);
    if(!apiConfig.ready) return true;
    try{ await apiCall('delete_invoice',{id}); return true; }catch(e){ return false; }
  },
  async getTemplates(){
    const cached = cache.get(KEYS.templates)||{};
    if(!apiConfig.ready) return cached;
    try{
      const r = await apiCall('get_templates');
      const merged = {};
      Object.entries(r.data||{}).forEach(([id,meta])=>{
        merged[id] = cached[id] ? {...meta, bgDataUrl:cached[id].bgDataUrl, termsBgDataUrl:cached[id].termsBgDataUrl} : meta;
      });
      return merged;
    }catch(e){ return cached; }
  },
  async saveTemplate(tpl){
    const ts = cache.get(KEYS.templates)||{};
    ts[tpl.id] = tpl; cache.set(KEYS.templates,ts);
    if(!apiConfig.ready) return true;
    try{ await apiCall('save_template',tpl); return true; }catch(e){ return false; }
  },
  async deleteTemplate(id){
    const ts = cache.get(KEYS.templates)||{};
    delete ts[id]; cache.set(KEYS.templates,ts);
    if(!apiConfig.ready) return true;
    try{ await apiCall('delete_template',{id}); return true; }catch(e){ return false; }
  },
  async getActive(){
    if(!apiConfig.ready) return cache.get(KEYS.active)||null;
    try{ const r=await apiCall('get_settings'); const id=r.data?.activeTemplate||null; cache.set(KEYS.active,id); return id; }
    catch(e){ return cache.get(KEYS.active)||null; }
  },
  async setActive(id){
    cache.set(KEYS.active,id);
    if(!apiConfig.ready) return;
    try{ await apiCall('set_active_template',{id}); }catch{}
  },
};

/* =====================================================================
   SYNC STATUS INDICATOR
   ===================================================================== */
function setSyncStatus(status, msg=''){
  const el = document.getElementById('sync-status');
  if(!el) return;
  const map = { syncing:['⟳','var(--muted)'], ok:['✓','var(--accent)'], error:['⚠','#c0392b'], offline:['◌','var(--muted)'] };
  const [icon, color] = map[status]||['',''];
  el.textContent = icon+(msg?' '+msg:'');
  el.style.color = color;
}

/* =====================================================================
   STATE
   ===================================================================== */
let state = {
  templates: {},
  invoices: [],
  activeTemplateId: null,
  page: 'home',
  builder: {
    id: null, name: '', bgDataUrl: null, bgWidth: 0, bgHeight: 0,
    displayWidth: 0, displayHeight: 0,
    termsBgDataUrl: null, termsWidth: 0, termsHeight: 0,
    fields: [], armedKey: null, selectedFid: null,
  },
  form: { editingId: null },
};

async function loadStateFromServer(){
  setSyncStatus('syncing','جاري التحميل...');
  try{
    const [invoices, templates, activeId] = await Promise.all([db.getInvoices(), db.getTemplates(), db.getActive()]);
    state.invoices = invoices;
    state.templates = templates;
    state.activeTemplateId = activeId;
    setSyncStatus('ok', apiConfig.ready?'متزامن':'محلي');
  }catch(e){
    setSyncStatus('error','خطأ في التحميل');
    state.invoices = cache.get(KEYS.invoices)||[];
    state.templates = cache.get(KEYS.templates)||{};
    state.activeTemplateId = cache.get(KEYS.active)||null;
  }
}

/* =====================================================================
   UTILITIES
   ===================================================================== */
function $(s, root=document){ return root.querySelector(s); }
function $$(s, root=document){ return [...root.querySelectorAll(s)]; }
function uid(p='id'){ return p+'-'+Date.now().toString(36)+'-'+Math.random().toString(36).slice(2,7); }

function toast(msg, type=''){
  const el = $('#toast');
  el.textContent = msg;
  el.className = 'toast show '+type;
  clearTimeout(toast._t);
  toast._t = setTimeout(()=>el.classList.remove('show'), 3200);
}

function escapeHTML(s){
  return String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

function fmtMoney(n){
  return Number(n||0).toLocaleString('en-US', { maximumFractionDigits:2 });
}

function fmtDate(iso){
  if(!iso) return '';
  const d = new Date(iso);
  if(isNaN(d)) return iso;
  const dd = String(d.getDate()).padStart(2,'0');
  const mm = String(d.getMonth()+1).padStart(2,'0');
  const yy = d.getFullYear();
  return `${dd} / ${mm} / ${yy} م`;
}

function currencySymbol(c){
  if(c==='ريال') return 'ر.س';
  if(c==='دولار') return '$';
  if(c==='درهم') return 'د.إ';
  return c||'';
}

function genDocNumber(){
  return 'FL-' + Math.floor(10000000 + Math.random()*90000000);
}

/* =====================================================================
   ROUTING
   ===================================================================== */
function goPage(name){
  state.page = name;
  $$('.page').forEach(p => p.classList.toggle('active', p.dataset.pg === name));
  $$('#nav button').forEach(b => b.classList.toggle('active', b.dataset.page === name));
  if(name === 'home') renderHome();
  if(name === 'invoices') renderInvoices();
  if(name === 'new') prepareForm();
  if(name === 'template') renderTemplatePage();
  if(name === 'settings') renderSettingsPage();
  window.scrollTo({top:0, behavior:'smooth'});
}

$$('#nav button').forEach(b => b.addEventListener('click', ()=>goPage(b.dataset.page)));

/* =====================================================================
   HOME
   ===================================================================== */
function renderHome(){
  // stats
  const total = state.invoices.length;
  const sum = state.invoices.reduce((s,i)=>s+(Number(i.price)||0), 0);
  const tpls = Object.keys(state.templates).length;
  $('#stats').innerHTML = `
    <div class="stat">
      <div class="lbl">Invoices</div>
      <div class="val">${total}</div>
    </div>
    <div class="stat">
      <div class="lbl">Total · SAR</div>
      <div class="val">${fmtMoney(sum)} <small>ر.س</small></div>
    </div>
    <div class="stat">
      <div class="lbl">Templates</div>
      <div class="val">${tpls}</div>
    </div>
  `;

  const recent = state.invoices.slice(0,5);
  if(!recent.length){
    $('#home-list').innerHTML = `<div class="empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="3" width="16" height="18" rx="2"/><line x1="8" y1="9" x2="16" y2="9"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>
      <h3>لا توجد فواتير بعد</h3>
      <p>ابدأ بتصميم نموذج ثم أنشئ فاتورتك الأولى</p>
    </div>`;
  } else {
    $('#home-list').innerHTML = recentTable(recent);
    bindRowActions('#home-list');
  }
}

/* =====================================================================
   INVOICES LIST
   ===================================================================== */
function renderInvoices(){
  if(!state.invoices.length){
    $('#invoices-list').innerHTML = `<div class="empty" style="padding:80px 20px">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="3" width="16" height="18" rx="2"/></svg>
      <h3>لا توجد فواتير</h3>
      <p>اضغط "فاتورة جديدة" لإنشاء أول فاتورة</p>
    </div>`;
    return;
  }
  $('#invoices-list').innerHTML = recentTable(state.invoices);
  bindRowActions('#invoices-list');
}

function recentTable(list){
  let html = `<table><thead><tr>
    <th>العميل</th><th>المشروع</th><th>رقم</th><th>النوع</th><th>التاريخ</th><th>السعر</th><th></th>
  </tr></thead><tbody>`;
  for(const inv of list){
    html += `<tr class="hover-row" data-id="${inv.id}">
      <td><strong>${escapeHTML(inv.client||'—')}</strong></td>
      <td>${escapeHTML(inv.project||'')}</td>
      <td><span class="doc-num">${escapeHTML(inv.docNumber||'')}</span></td>
      <td><span class="badge ${inv.type==='فاتورة'?'badge-invoice':'badge-quote'}">${escapeHTML(inv.type||'عرض سعر')}</span></td>
      <td>${escapeHTML(fmtDate(inv.date))}</td>
      <td class="price">${fmtMoney(inv.price)} <small style="color:var(--muted);font-weight:500">${escapeHTML(currencySymbol(inv.currency))}</small></td>
      <td><div class="row-actions">
        <button class="icon-btn" data-act="export" title="تصدير PDF"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button>
        <button class="icon-btn" data-act="edit" title="تعديل"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
        <button class="icon-btn danger" data-act="delete" title="حذف"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg></button>
      </div></td>
    </tr>`;
  }
  return html + `</tbody></table>`;
}

function bindRowActions(rootSel){
  $$(rootSel+' tr.hover-row').forEach(tr => {
    tr.addEventListener('click', e => {
      const act = e.target.closest('[data-act]')?.dataset.act;
      const id = tr.dataset.id;
      if(act === 'edit')   editInvoice(id);
      else if(act === 'delete') deleteInvoice(id);
      else if(act === 'export') exportInvoiceById(id);
      else editInvoice(id);
    });
  });
}

/* =====================================================================
   FORM (NEW / EDIT)
   ===================================================================== */
function prepareForm(){
  // show warning if no templates
  $('#no-template-warn').style.display = Object.keys(state.templates).length ? 'none' : 'block';
  if(!state.form.editingId){
    $('#form-title').textContent = 'فاتورة جديدة';
    $('#form-sub').textContent = 'عبّي البيانات ثم اضغط حفظ أو تصدير PDF';
    $('#f-type').value = 'عرض سعر';
    $('#f-docNumber').value = '';
    $('#f-client').value = '';
    $('#f-firstParty').value = 'إسماعيل الحربي';
    $('#f-project').value = '';
    $('#f-projectType').value = '';
    $('#f-date').value = new Date().toISOString().slice(0,10);
    $('#f-price').value = '';
    $('#f-currency').value = 'ريال';
    $('#f-bankName').value = 'بنك الراجحي';
    $('#f-account').value = 'SA3580000280608016255698';
    $('#f-notes').value = '';
    resetItemsState();
  }
}

function readForm(){
  return {
    type: $('#f-type').value,
    docNumber: $('#f-docNumber').value.trim() || genDocNumber(),
    client: $('#f-client').value.trim(),
    firstParty: $('#f-firstParty').value.trim(),
    project: $('#f-project').value.trim(),
    projectType: $('#f-projectType').value.trim(),
    date: $('#f-date').value,
    price: Number($('#f-price').value)||0,
    currency: $('#f-currency').value,
    items: $('#f-items').value.trim(),
    bankName: $('#f-bankName').value.trim(),
    account: $('#f-account').value.trim(),
    notes: $('#f-notes').value.trim(),
  };
}

function fillForm(inv){
  $('#f-type').value = inv.type || 'عرض سعر';
  $('#f-docNumber').value = inv.docNumber || '';
  $('#f-client').value = inv.client || '';
  $('#f-firstParty').value = inv.firstParty || '';
  $('#f-project').value = inv.project || '';
  $('#f-projectType').value = inv.projectType || '';
  $('#f-date').value = inv.date || '';
  $('#f-price').value = inv.price || '';
  $('#f-currency').value = inv.currency || 'ريال';
  $('#f-bankName').value = inv.bankName || '';
  $('#f-account').value = inv.account || '';
  $('#f-notes').value = inv.notes || '';
  loadItemsFromText(inv.items || '');
}

async function saveInvoice(){
  const data = readForm();
  if(!data.client || !data.project){
    toast('اسم العميل والمشروع مطلوبان','error');
    return null;
  }
  let inv;
  if(state.form.editingId){
    const idx = state.invoices.findIndex(x=>x.id===state.form.editingId);
    if(idx>=0){
      state.invoices[idx] = {...state.invoices[idx], ...data};
      inv = state.invoices[idx];
    }
  } else {
    inv = { id: uid('inv'), ...data, createdAt: Date.now() };
    state.invoices.unshift(inv);
  }
  setSyncStatus('syncing','');
  await db.saveInvoice(inv);
  setSyncStatus('ok',apiConfig.ready?'متزامن':'محلي');
  toast('تم الحفظ', 'success');
  return inv;
}

async function saveAndExport(){
  const inv = await saveInvoice();
  if(!inv) return;
  const tplId = state.activeTemplateId || Object.keys(state.templates)[0];
  if(!tplId){
    toast('يجب تصميم نموذج أولاً','error');
    goPage('template');
    return;
  }
  await exportInvoice(inv, tplId);
  // stay on form; user can keep editing
}

function editInvoice(id){
  const inv = state.invoices.find(x=>x.id===id);
  if(!inv) return;
  state.form.editingId = id;
  goPage('new');
  $('#form-title').textContent = 'تعديل فاتورة';
  $('#form-sub').textContent = inv.client + ' · ' + inv.project;
  fillForm(inv);
}

async function deleteInvoice(id){
  if(!confirm('حذف هذه الفاتورة؟')) return;
  state.invoices = state.invoices.filter(x=>x.id!==id);
  await db.deleteInvoice(id);
  toast('تم الحذف','');
  if(state.page==='home') renderHome();
  else if(state.page==='invoices') renderInvoices();
}

async function exportInvoiceById(id){
  const inv = state.invoices.find(x=>x.id===id);
  if(!inv) return;
  const tplId = state.activeTemplateId || Object.keys(state.templates)[0];
  if(!tplId){
    toast('يجب تصميم نموذج أولاً','error');
    return;
  }
  await exportInvoice(inv, tplId);
}

// reset editingId whenever leaving the form
const origGoPage = goPage;
window.goPage = function(name){
  if(state.page==='new' && name!=='new'){ state.form.editingId = null; }
  origGoPage(name);
};

/* =====================================================================
   TEMPLATE BUILDER
   ===================================================================== */
function renderTemplatePage(){
  // show empty/builder based on builder state
  if(state.builder.bgDataUrl){
    showBuilder();
  } else {
    showEmpty();
  }
}

function showEmpty(){
  $('#tpl-empty').hidden = false;
  $('#tpl-builder').hidden = true;
  $('#tpl-save').hidden = true;
  $('#tpl-reset').hidden = true;
  renderSavedTemplates();
}

function showBuilder(){
  $('#tpl-empty').hidden = true;
  $('#tpl-builder').hidden = false;
  $('#tpl-save').hidden = false;
  $('#tpl-reset').hidden = false;
  $('#tpl-name').value = state.builder.name || 'نموذج بدون اسم';
  $('#tpl-info').textContent = `${state.builder.bgWidth}×${state.builder.bgHeight} px`;
  buildStage();
  renderChips();
  renderProps();
  // always start on main page tab
  switchTplPage('main');
}

function renderSavedTemplates(){
  const host = $('#saved-tpls');
  const list = Object.values(state.templates).sort((a,b)=> (b.createdAt||0)-(a.createdAt||0));
  if(!list.length){
    host.innerHTML = `<div class="empty" style="padding:30px 20px">
      <p>لا توجد نماذج محفوظة. ارفع صورة الخلفية لتبدأ.</p>
    </div>`;
    return;
  }
  host.innerHTML = '';
  for(const t of list){
    const isActive = t.id === state.activeTemplateId;
    const div = document.createElement('div');
    div.className = 'saved-tpl' + (isActive ? ' active' : '');
    div.innerHTML = `
      <div class="thumb" style="background-image:url('${t.bgDataUrl}')"></div>
      <div class="info">
        <div class="nm">${escapeHTML(t.name)}</div>
        <div class="meta">${(t.fields||[]).length} حقل · ${t.bgWidth}×${t.bgHeight}</div>
      </div>
      <div class="actions">
        ${isActive ? '' : '<button class="btn btn-sm btn-ghost" data-act="activate">تفعيل</button>'}
        <button class="btn btn-sm btn-ghost" data-act="edit">تعديل</button>
        <button class="btn btn-sm btn-danger" data-act="delete">حذف</button>
      </div>
    `;
    div.querySelector('[data-act="activate"]')?.addEventListener('click', async ()=>{
      state.activeTemplateId = t.id;
      await db.setActive(t.id);
      toast('تم تفعيل النموذج','success');
      renderSavedTemplates();
    });
    div.querySelector('[data-act="edit"]').addEventListener('click', ()=>tplLoadForEdit(t.id));
    div.querySelector('[data-act="delete"]').addEventListener('click', async ()=>{
      if(!confirm('حذف هذا النموذج؟')) return;
      delete state.templates[t.id];
      if(state.activeTemplateId === t.id){
        state.activeTemplateId = Object.keys(state.templates)[0] || null;
        await db.setActive(state.activeTemplateId);
      }
      await db.deleteTemplate(t.id);
      toast('تم الحذف','');
      renderSavedTemplates();
    });
    host.appendChild(div);
  }
}

function tplUpload(ev){
  const file = ev.target.files?.[0];
  if(!file) return;
  if(!file.type.startsWith('image/')){
    toast('يجب أن يكون ملف صورة','error');
    return;
  }
  const reader = new FileReader();
  reader.onload = e => {
    const dataUrl = e.target.result;
    const img = new Image();
    img.onload = () => {
      // size limit: prevent storage quota issues
      const MAX = 2400;
      let w = img.naturalWidth, h = img.naturalHeight;
      if(w > MAX || h > MAX){
        const ratio = Math.min(MAX/w, MAX/h);
        w = Math.round(w*ratio);
        h = Math.round(h*ratio);
        const cv = document.createElement('canvas');
        cv.width = w; cv.height = h;
        cv.getContext('2d').drawImage(img, 0, 0, w, h);
        startBuilderWith(cv.toDataURL('image/jpeg', 0.92), w, h, file.name);
      } else {
        startBuilderWith(dataUrl, w, h, file.name);
      }
    };
    img.onerror = () => toast('تعذر قراءة الصورة','error');
    img.src = dataUrl;
  };
  reader.readAsDataURL(file);
  ev.target.value = '';
}

function startBuilderWith(dataUrl, w, h, fileName){
  state.builder = {
    id: uid('tpl'),
    name: (fileName||'نموذج').replace(/\.[^.]+$/,''),
    bgDataUrl: dataUrl,
    bgWidth: w,
    bgHeight: h,
    displayWidth: 0,
    displayHeight: 0,
    termsBgDataUrl: null,
    termsWidth: 0,
    termsHeight: 0,
    fields: [],
    armedKey: null,
    selectedFid: null,
  };
  showBuilder();
}

function tplLoadForEdit(id){
  const t = state.templates[id];
  if(!t) return;
  state.builder = {
    id: t.id,
    name: t.name,
    bgDataUrl: t.bgDataUrl,
    bgWidth: t.bgWidth,
