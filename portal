  'تصميم بروفايل Profile Design':'profile',
  'تصميم كتب Book Design':'book',
};

let itemsState = { selected:new Set(), custom:[] };

function getTypeKey(){
  const el = document.getElementById('f-projectType');
  return el ? (TYPE_KEY_MAP[el.value] || null) : null;
}

function onProjectTypeChange(){
  const typeKey = getTypeKey();
  if(typeKey){
    itemsState.selected = new Set([...itemsState.selected].filter(id=>{
      if(id.startsWith('custom-')) return true;
      const item = ALL_ITEMS.find(x=>x.id===id);
      return item && item.types.includes(typeKey);
    }));
  }
  renderItemsCheckboxes();
}

function renderItemsCheckboxes(){
  const host = document.getElementById('items-checkboxes');
  if(!host) return;
  const typeKey = getTypeKey();
  const visible = typeKey ? ALL_ITEMS.filter(i=>i.types.includes(typeKey)) : ALL_ITEMS;
  host.innerHTML='';
  visible.forEach(item=>{
    const checked = itemsState.selected.has(item.id);
    const row = document.createElement('div');
    row.className = 'item-row'+(checked?' checked':'');
    row.innerHTML = `<input type="checkbox" id="chk-${item.id}" ${checked?'checked':''}/>
      <label class="item-text" for="chk-${item.id}">${item.text.replace(/</g,'&lt;')}</label>`;
    row.querySelector('input').addEventListener('change',e=>{
      if(e.target.checked) itemsState.selected.add(item.id);
      else itemsState.selected.delete(item.id);
      row.classList.toggle('checked',e.target.checked);
      syncItemsTextarea();
    });
    row.addEventListener('click',e=>{
      if(e.target.tagName==='INPUT'||e.target.tagName==='LABEL') return;
      const cb=row.querySelector('input'); cb.checked=!cb.checked;
      cb.dispatchEvent(new Event('change'));
    });
    host.appendChild(row);
  });
  if(itemsState.custom.length){
    const hr=document.createElement('div');
    hr.innerHTML='<hr style="border:none;border-top:1px dashed var(--line);margin:4px 8px"/>';
    host.appendChild(hr);
    itemsState.custom.forEach((text,ci)=>{
      const cid='custom-'+ci;
      const checked=itemsState.selected.has(cid);
      const row=document.createElement('div');
      row.className='item-row'+(checked?' checked':'');
      row.innerHTML=`<input type="checkbox" id="chk-${cid}" ${checked?'checked':''}/>
        <label class="item-text" for="chk-${cid}">${text.replace(/</g,'&lt;')}</label>
        <button type="button" style="color:var(--danger);font-size:16px;line-height:1;padding:0 4px;flex-shrink:0" onclick="removeCustomItem(${ci})">×</button>`;
      row.querySelector('input').addEventListener('change',e=>{
        if(e.target.checked) itemsState.selected.add(cid);
        else itemsState.selected.delete(cid);
        row.classList.toggle('checked',e.target.checked);
        syncItemsTextarea();
      });
      host.appendChild(row);
    });
  }
  syncItemsTextarea();
}

function addCustomItem(){
  const inp=document.getElementById('custom-item-input');
  const text=inp.value.trim(); if(!text) return;
  const cid='custom-'+itemsState.custom.length;
  itemsState.custom.push(text); itemsState.selected.add(cid);
  inp.value=''; renderItemsCheckboxes();
}
document.addEventListener('keydown',e=>{
  if(e.target.id==='custom-item-input'&&e.key==='Enter'){e.preventDefault();addCustomItem();}
});
function removeCustomItem(ci){
  itemsState.custom.splice(ci,1);
  const kept=new Set([...itemsState.selected].filter(id=>!id.startsWith('custom-')));
  itemsState.custom.forEach((_,i)=>{ if(itemsState.selected.has('custom-'+(i+1))) kept.add('custom-'+i); });
  itemsState.selected=kept; renderItemsCheckboxes();
}
function syncItemsTextarea(){
  const lines=[];
  ALL_ITEMS.forEach(item=>{ if(itemsState.selected.has(item.id)) lines.push(item.text); });
  itemsState.custom.forEach((text,ci)=>{ if(itemsState.selected.has('custom-'+ci)) lines.push(text); });
  const ta=document.getElementById('f-items'); if(ta) ta.value=lines.join('\n');
  const count=lines.length;
  const lbl=document.getElementById('items-count-label');
  if(lbl) lbl.textContent=count>0?count+' بند محدد':'لا يوجد تحديد';
  const prev=document.getElementById('items-preview-row');
  if(prev){
    if(count>0){
      prev.hidden=false;
      const short=lines.slice(0,2).map(l=>l.slice(0,32)+(l.length>32?'…':'')).join(' · ');
      const sp=document.getElementById('items-selected-preview');
      if(sp) sp.textContent=short+(count>2?' (+'+( count-2)+')':'');
    } else prev.hidden=true;
  }
}
function resetItemsState(){ itemsState={selected:new Set(),custom:[]}; renderItemsCheckboxes(); }
function loadItemsFromText(text){
  itemsState={selected:new Set(),custom:[]};
  if(!text){ renderItemsCheckboxes(); return; }
  text.split('\n').map(l=>l.trim()).filter(Boolean).forEach(line=>{
    const match=ALL_ITEMS.find(i=>i.text===line);
    if(match) itemsState.selected.add(match.id);
    else { const ci=itemsState.custom.length; itemsState.custom.push(line); itemsState.selected.add('custom-'+ci); }
  });
  renderItemsCheckboxes();
}

