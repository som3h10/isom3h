    displayHeight: 0,
    termsBgDataUrl: t.termsBgDataUrl || null,
    termsWidth: t.termsWidth || 0,
    termsHeight: t.termsHeight || 0,
    fields: (t.fields||[]).map(f => ({...f, fid: uid('f')})),
