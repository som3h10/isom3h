}

// Bind segmented controls (event delegation for buttons inside .seg)
document.addEventListener('click', (e)=>{
  const btn = e.target.closest('.seg button');
  if(!btn) return;
  const seg = btn.parentElement;
  if(!state.builder.selectedFid) return;
  const fld = state.builder.fields.find(f => f.fid === state.builder.selectedFid);
  if(!fld) return;
  const val = btn.dataset.val;
  if(seg.id === 'p-dir-seg'){
    fld.dir = val;
    // auto-adjust default align when direction flips
    if(fld.align !== 'center'){
      fld.align = val === 'rtl' ? 'right' : 'left';
      setSegValue('p-align-seg', fld.align);
    }
  } else if(seg.id === 'p-align-seg'){
    fld.align = val;
  } else if(seg.id === 'p-valign-seg'){
    fld.valign = val;
  }
  $$('button', seg).forEach(b => b.classList.toggle('on', b.dataset.val === val));
  renderFieldBoxes();
});

// hex input → sync color
document.addEventListener('input', e => {
  if(e.target.id !== 'p-color-hex') return;
  if(!state.builder.selectedFid) return;
  let v = e.target.value.trim();
  if(!v.startsWith('#')) v = '#' + v;
  if(/^#[0-9a-fA-F]{6}$/.test(v) || /^#[0-9a-fA-F]{3}$/.test(v)){
    const fld = state.builder.fields.find(f => f.fid === state.builder.selectedFid);
    if(!fld) return;
    fld.color = v;
    $('#p-color').value = v;
