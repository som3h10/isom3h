</header>

<main class="container">

  <!-- ============ HOME ============ -->
  <section class="page active" data-pg="home">
    <div class="page-head">
      <div>
        <h2>أهلاً بك</h2>
        <div class="sub">ابدأ بتصميم نموذج الفاتورة، ثم أنشئ فواتير من الفورم</div>
      </div>
      <div class="page-actions">
        <button class="btn btn-ghost" onclick="goPage('template')">تصميم نموذج</button>
        <button class="btn btn-primary" onclick="goPage('new')">+ فاتورة جديدة</button>
      </div>
    </div>

    <div class="stats" id="stats"></div>

    <div class="card">
      <h3 style="font-size:16px;font-weight:700;margin-bottom:12px">آخر الفواتير</h3>
      <div id="home-list"></div>
    </div>
  </section>

  <!-- ============ INVOICES LIST ============ -->
  <section class="page" data-pg="invoices">
    <div class="page-head">
      <div>
        <h2>الفواتير</h2>
        <div class="sub">جميع الفواتير المحفوظة</div>
      </div>
      <div class="page-actions">
        <button class="btn btn-primary" onclick="goPage('new')">+ فاتورة جديدة</button>
      </div>
    </div>
    <div class="card" style="padding:0;overflow:hidden">
      <div id="invoices-list"></div>
    </div>
  </section>

  <!-- ============ NEW / EDIT INVOICE ============ -->
  <section class="page" data-pg="new">
    <div class="page-head">
      <div>
        <h2 id="form-title">فاتورة جديدة</h2>
        <div class="sub" id="form-sub">عبّي البيانات ثم اضغط حفظ أو تصدير PDF</div>
      </div>
      <div class="page-actions">
        <button class="btn btn-ghost" onclick="goPage('invoices')">إلغاء</button>
        <button class="btn btn-primary" onclick="saveInvoice()">حفظ</button>
        <button class="btn btn-accent" onclick="saveAndExport()" id="export-btn">تصدير PDF</button>
      </div>
    </div>

    <div id="no-template-warn" class="card" style="background:rgba(181,69,69,0.06);border-color:rgba(181,69,69,0.2);margin-bottom:16px;display:none">
      <strong style="color:var(--danger)">لم تصمم نموذج بعد</strong>
      <p style="margin-top:6px;font-size:14px;color:var(--ink-soft)">
        قبل إنشاء فاتورة، يجب تصميم نموذج (رفع صورة الخلفية وتحديد أماكن الحقول).
        <button class="btn btn-sm btn-ghost" style="margin-right:8px" onclick="goPage('template')">انتقل لتصميم النموذج</button>
      </p>
    </div>

    <div class="card">
      <div class="form-grid">
        <div class="field">
          <label>نوع الوثيقة</label>
          <select id="f-type">
            <option value="عرض سعر">عرض سعر</option>
            <option value="فاتورة">فاتورة</option>
          </select>
        </div>
        <div class="field">
          <label>رقم الوثيقة</label>
          <input type="text" id="f-docNumber" placeholder="FL-46140955" />
          <div class="hint">يُولّد تلقائياً إذا تركته فارغاً</div>
        </div>

        <div class="field">
          <label>اسم العميل (الطرف الثاني) <span class="req">*</span></label>
          <input type="text" id="f-client" placeholder="KAD - كاد" />
        </div>
        <div class="field">
          <label>الطرف الأول</label>
          <input type="text" id="f-firstParty" placeholder="إسماعيل الحربي" />
        </div>

        <div class="field full">
          <label>اسم المشروع <span class="req">*</span></label>
          <input type="text" id="f-project" placeholder="تصميم هوية بصرية" />
        </div>

        <div class="field">
          <label>نوع المشروع</label>
          <select id="f-projectType" onchange="onProjectTypeChange()">
            <option value="">— اختر نوع المشروع —</option>
            <option value="تصميم شعار Logo">تصميم شعار — Logo</option>
            <option value="تصميم هوية بصرية Visual Identity">تصميم هوية بصرية — Visual Identity</option>
            <option value="تصميم منشورات تواصل اجتماعي Social Media Post">تصميم منشورات تواصل اجتماعي — Social Media Post</option>
            <option value="تصميم بروفايل Profile Design">تصميم بروفايل — Profile Design</option>
            <option value="تصميم كتب Book Design">تصميم كتب — Book Design</option>
          </select>
        </div>
        <div class="field">
          <label>تاريخ الإصدار</label>
          <input type="date" id="f-date" />
        </div>

        <div class="field">
          <label>السعر <span class="req">*</span></label>
          <input type="number" id="f-price" step="0.01" placeholder="2500" />
        </div>
        <div class="field">
          <label>العملة</label>
          <select id="f-currency">
            <option value="ريال">ريال سعودي (ر.س)</option>
            <option value="دولار">دولار ($)</option>
            <option value="درهم">درهم (د.إ)</option>
          </select>
        </div>

        <div class="field full">
          <label>بنود المشروع</label>
          <div class="items-section">
            <div class="items-header">
              <span>اختر البنود</span>
              <span id="items-count-label">0 بند محدد</span>
            </div>
            <div class="items-list" id="items-checkboxes"></div>
            <div class="items-preview" id="items-preview-row" hidden>
              محدد: <span id="items-selected-preview">—</span>
            </div>
            <div class="items-custom">
              <input type="text" id="custom-item-input" placeholder="أضف بنداً مخصصاً..." />
              <button type="button" onclick="addCustomItem()">+ إضافة</button>
            </div>
          </div>
          <!-- hidden textarea يحمل القيمة الفعلية -->
          <textarea id="f-items" style="display:none"></textarea>
        </div>

        <div class="field">
          <label>اسم البنك</label>
          <input type="text" id="f-bankName" placeholder="بنك الراجحي" />
        </div>
        <div class="field">
          <label>رقم الحساب / IBAN</label>
          <input type="text" id="f-account" placeholder="SA3580000280608016255698" />
        </div>

        <div class="field full">
          <label>ملاحظات</label>
          <textarea id="f-notes" rows="2" placeholder="ملاحظات إضافية..."></textarea>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TEMPLATE BUILDER ============ -->
  <section class="page" data-pg="template">
    <div class="page-head">
      <div>
        <h2>تصميم نموذج الفاتورة</h2>
        <div class="sub">ارفع صورة الخلفية وحدد أماكن البيانات على التصميم</div>
      </div>
      <div class="page-actions">
        <button class="btn btn-danger btn-sm" id="tpl-reset" onclick="tplResetCurrent()" hidden>إعادة تعيين</button>
        <button class="btn btn-accent" id="tpl-save" onclick="tplSaveCurrent()" hidden>حفظ النموذج</button>
      </div>
    </div>

    <!-- Empty state: upload + saved templates -->
    <div id="tpl-empty">
      <div class="card" style="margin-bottom:16px">
        <label class="upload-area">
          <div class="upload-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 16 12 12 8 16"/>
              <line x1="12" y1="12" x2="12" y2="21"/>
              <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
            </svg>
          </div>
          <div class="upload-body">
            <h3>ارفع صورة خلفية الفاتورة</h3>
            <p>JPG / PNG · أفضل دقة A4 @ 300dpi</p>
          </div>
          <span class="upload-btn">اختر صورة</span>
          <input type="file" accept="image/*" onchange="tplUpload(event)" />
        </label>
      </div>

      <div class="card">
        <h3 style="font-size:16px;font-weight:700;margin-bottom:14px">النماذج المحفوظة</h3>
        <div id="saved-tpls" class="saved-tpls-list"></div>
      </div>
    </div>

    <!-- Builder mode -->
    <div id="tpl-builder" hidden>
      <div class="help">
        <strong>كيفية الاستخدام:</strong>
        ١) اضغط على اسم حقل من اللوحة الجانبية ←
        ٢) انقر على المكان المطلوب فوق صورة الفاتورة لوضعه ←
        ٣) اسحبه لتحريكه أو اسحب الزاوية لتغيير الحجم ←
        ٤) عدّل الخصائص (الخط، الحجم، اللون) من اللوحة ←
        ٥) اضغط <strong>حفظ النموذج</strong>
      </div>

      <div class="tpl-layout">
        <div class="stage-wrap">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px">
            <input type="text" id="tpl-name" placeholder="اسم النموذج..." 
              style="flex:1;min-width:200px;padding:9px 14px;border:1px solid var(--line-strong);border-radius:8px;font-size:14px" />
            <div style="font-size:13px;color:var(--muted)" id="tpl-info">—</div>
          </div>

          <!-- Page tabs -->
          <div class="page-tabs">
            <button class="page-tab on" data-tpage="main" onclick="switchTplPage('main')">
              <strong>الصفحة 1</strong>
              <small>الفاتورة (مع الحقول)</small>
            </button>
            <button class="page-tab" data-tpage="terms" onclick="switchTplPage('terms')">
              <strong>الصفحة 2</strong>
              <small>الشروط والأحكام</small>
            </button>
          </div>

          <div id="stage-host"></div>

          <!-- Terms page panel (hidden by default) -->
          <div id="terms-host" hidden>
            <div id="terms-empty">
              <label class="upload-area" style="margin-top:10px">
                <div class="upload-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                  </svg>
                </div>
                <div class="upload-body">
                  <h3>صفحة الشروط والأحكام</h3>
                  <p>تُضاف للـ PDF بدون تعديلات · اختياري</p>
                </div>
                <span class="upload-btn">اختر صورة</span>
                <input type="file" accept="image/*" onchange="tplUploadTerms(event)" />
              </label>
            </div>
            <div id="terms-preview" hidden>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;padding:12px 16px;background:var(--bg);border-radius:8px">
                <div>
                  <div style="font-weight:700;font-size:14px">صفحة الشروط جاهزة</div>
                  <div style="color:var(--muted);font-size:12px;margin-top:2px" id="terms-info">—</div>
                </div>
                <button class="btn btn-sm btn-danger" onclick="removeTplTerms()">إزالة</button>
              </div>
              <div id="terms-img-wrap" style="text-align:center"></div>
            </div>
          </div>
        </div>

        <aside class="builder-sidebar">
          <div class="panel">
            <h4>الحقول المتاحة <span class="count" id="fields-count">0</span></h4>
            <div class="field-chips" id="chips"></div>
          </div>

          <div class="panel" id="props-panel">
            <h4>خصائص الحقل</h4>
            <div id="props-empty" class="prop-empty">اختر حقلاً للتعديل</div>
            <div id="props-form" hidden>
              <div class="prop-grid">

                <div class="full">
                  <label>اتجاه النص</label>
                  <div class="seg" id="p-dir-seg">
                    <button type="button" data-val="rtl" title="عربي - من اليمين لليسار">
                      <span style="font-weight:800">ا ب</span>
                      <small>RTL</small>
                    </button>
                    <button type="button" data-val="ltr" title="إنجليزي - من اليسار لليمين">
                      <span style="font-weight:800">A B</span>
                      <small>LTR</small>
                    </button>
                  </div>
                </div>

                <div class="full">
                  <label>محاذاة أفقية</label>
                  <div class="seg" id="p-align-seg">
                    <button type="button" data-val="right" title="يمين">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="12" x2="9" y2="12"/><line x1="21" y1="18" x2="7" y2="18"/></svg>
                    </button>
                    <button type="button" data-val="center" title="وسط">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="21" y1="6" x2="3" y2="6"/><line x1="17" y1="12" x2="7" y2="12"/><line x1="19" y1="18" x2="5" y2="18"/></svg>
                    </button>
                    <button type="button" data-val="left" title="يسار">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="21" y1="6" x2="3" y2="6"/><line x1="15" y1="12" x2="3" y2="12"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                    </button>
                  </div>
                </div>

                <div class="full">
                  <label>محاذاة عمودية</label>
                  <div class="seg" id="p-valign-seg">
                    <button type="button" data-val="top" title="أعلى">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="4" x2="21" y2="4"/><rect x="6" y="8" width="12" height="6"/></svg>
                    </button>
                    <button type="button" data-val="center" title="وسط">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><rect x="6" y="6" width="12" height="6"/></svg>
                    </button>
                    <button type="button" data-val="bottom" title="أسفل">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="20" x2="21" y2="20"/><rect x="6" y="10" width="12" height="6"/></svg>
                    </button>
                  </div>
                </div>

                <div>
                  <label>حجم الخط</label>
                  <input type="number" id="p-size" min="6" max="200" />
                </div>
                <div>
                  <label>وزن الخط</label>
                  <select id="p-weight">
                    <option value="300">رفيع</option>
                    <option value="400">عادي</option>
                    <option value="500">متوسط</option>
                    <option value="700">عريض</option>
                    <option value="800">عريض جداً</option>
                    <option value="900">أسود</option>
                  </select>
                </div>

                <div class="full">
                  <label>اللون</label>
                  <div class="color-row">
                    <input type="color" id="p-color" />
                    <input type="text" id="p-color-hex" maxlength="7" placeholder="#000000" />
                  </div>
                  <div class="color-swatches" id="p-swatches"></div>
                </div>

                <div>
                  <label>تباعد السطر</label>
                  <input type="number" id="p-lineHeight" step="0.05" min="0.8" max="3" />
                </div>
                <div>
                  <label>تباعد الحروف</label>
                  <input type="number" id="p-letterSpacing" step="0.5" />
                </div>

                <div>
                  <label>X</label>
                  <input type="number" id="p-x" />
                </div>
                <div>
                  <label>Y</label>
                  <input type="number" id="p-y" />
                </div>
                <div>
                  <label>العرض</label>
                  <input type="number" id="p-w" />
                </div>
                <div>
                  <label>الارتفاع</label>
                  <input type="number" id="p-h" />
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

</main>

<!-- ============ SETTINGS ============ -->
  <section class="page" data-pg="settings">
    <div class="page-head">
      <div>
        <h2>الإعدادات</h2>
        <div class="sub">اربط البرنامج بسيرفر WordPress لحفظ البيانات من أي مكان</div>
      </div>
    </div>

    <div class="card" style="max-width:600px">
      <div style="font-size:0.7rem;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--line)">ربط السيرفر</div>

      <div style="background:var(--accent-light);border-right:3px solid var(--accent);padding:12px 14px;border-radius:6px;margin-bottom:20px;font-size:0.82rem;line-height:1.7">
        <strong style="display:block;margin-bottom:4px">خطوات الإعداد:</strong>
        ١) حمّل ملف <code style="background:white;padding:1px 6px;border-radius:4px;font-size:0.78rem">invoices-api.php</code> وارفعه على WordPress<br>
        ٢) افتح الملف وغيّر <code style="background:white;padding:1px 6px;border-radius:4px;font-size:0.78rem">API_SECRET</code> لكلمة سر خاصة بك<br>
        ٣) أدخل رابط الملف والمفتاح أدناه واضغط اختبار
      </div>

      <div style="display:flex;flex-direction:column;gap:14px">
        <div class="field">
          <label>رابط الـ API (رابط ملف invoices-api.php)</label>
          <input type="url" id="s-api-url" placeholder="https://موقعك.com/wp-content/uploads/invoices-app/invoices-api.php" style="direction:ltr;text-align:left" />
        </div>
        <div class="field">
          <label>المفتاح السري (API_SECRET)</label>
          <input type="password" id="s-api-key" placeholder="نفس القيمة التي وضعتها في الملف" />
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button class="btn btn-accent" onclick="saveApiSettings()">حفظ الإعدادات</button>
          <button class="btn btn-ghost" onclick="testApiConnection()">اختبار الاتصال</button>
          <button class="btn btn-ghost" onclick="syncFromServer()">↓ مزامنة من السيرفر</button>
        </div>
        <div id="api-test-result" style="font-size:0.82rem;min-height:20px"></div>
      </div>

      <div style="border-top:1px solid var(--line);margin-top:20px;padding-top:16px">
        <div style="font-size:0.7rem;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px">الحالة</div>
        <div id="settings-status" style="font-size:0.85rem;color:var(--muted)">لم يتم ضبط API بعد — البيانات محفوظة محلياً فقط</div>
      </div>
