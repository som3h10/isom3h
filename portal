<script type="text/plain" id="php-source">
<?php
/**
 * invoices-api.php
 * ارفع هذا الملف في مجلد: wp-content/uploads/invoices-app/
 * الرابط سيكون: https://موقعك.com/wp-content/uploads/invoices-app/invoices-api.php
