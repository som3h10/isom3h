async function testApiConnection(){
  const url = document.getElementById('s-api-url')?.value.trim();
  const key = document.getElementById('s-api-key')?.value.trim();
  const res = document.getElementById('api-test-result');
  if(!url || !key){ if(res) res.textContent = '⚠ أدخل الرابط والمفتاح أولاً'; return; }
  if(res) res.innerHTML = '<span style="color:var(--muted)">⟳ جاري الاختبار...</span>';
  try{
    const testUrl = new URL(url);
    testUrl.searchParams.set('action','ping');
    const r = await fetch(testUrl.toString(), { headers:{'X-Api-Key':key} });
    const j = await r.json();
    if(j.ok){
      if(res) res.innerHTML = `<span style="color:var(--accent)">✓ الاتصال ناجح — ${j.msg}</span>`;
    } else {
      if(res) res.innerHTML = `<span style="color:#c0392b">✗ ${j.error||'خطأ غير معروف'}</span>`;
    }
  }catch(e){
    if(res) res.innerHTML = `<span style="color:#c0392b">✗ تعذر الاتصال: ${e.message}</span>`;
  }
}

