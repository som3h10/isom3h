    if(!confirm('لم تضع أي حقل ولم ترفع صفحة الشروط. حفظ على أي حال؟')) return;
  }
  const id = state.builder.id || uid('tpl');
  // store fields in display coordinates - simpler since we render at same display size
  const tpl = {
    id,
    name,
    bgDataUrl: state.builder.bgDataUrl,
    bgWidth: state.builder.bgWidth,
    bgHeight: state.builder.bgHeight,
    displayWidth: state.builder.displayWidth,
    displayHeight: state.builder.displayHeight,
    // optional second page (terms & conditions, used as-is, no fields)
    termsBgDataUrl: state.builder.termsBgDataUrl || null,
    termsWidth: state.builder.termsWidth || 0,
    termsHeight: state.builder.termsHeight || 0,
