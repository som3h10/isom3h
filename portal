// ============================================================
// الإعدادات — غيّر هذه القيم
// ============================================================
define('API_SECRET', 'CHANGE_THIS_SECRET_KEY_123');   // ← غيّر هذا المفتاح السري
define('ALLOWED_ORIGIN', '*');                          // ← ضع رابط موقعك مثل: 'https://isom3h.com'

// ============================================================
// بوت سترب
// ============================================================
// منع الوصول المباشر من المتصفح بدون مفتاح
if(empty($_SERVER['HTTP_X_API_KEY']) && empty($_GET['key'])){
    http_response_code(403);
    die(json_encode(['error'=>'Unauthorized']));
}

// التحقق من المفتاح
$provided_key = $_SERVER['HTTP_X_API_KEY'] ?? $_GET['key'] ?? '';
if($provided_key !== API_SECRET){
    http_response_code(403);
    die(json_encode(['error'=>'Invalid key']));
}

// CORS headers
header('Access-Control-Allow-Origin: ' . ALLOWED_ORIGIN);
header('Access-Control-Allow-Methods: GET, POST, DELETE, OPTIONS');
header('Access-Control-Allow-Headers: Content-Type, X-Api-Key');
header('Content-Type: application/json; charset=utf-8');

if($_SERVER['REQUEST_METHOD'] === 'OPTIONS'){
    http_response_code(200);
    exit;
}

// تحميل WordPress لاستخدام قاعدة البيانات
$wp_load = dirname(__FILE__);
// الصعود في المجلدات للوصول لـ wp-load.php
for($i = 0; $i < 6; $i++){
    $wp_load = dirname($wp_load);
    if(file_exists($wp_load . '/wp-load.php')){
        require_once($wp_load . '/wp-load.php');
        break;
    }
}

if(!defined('ABSPATH')){
    http_response_code(500);
    die(json_encode(['error'=>'WordPress not found']));
}

// ============================================================
// Router
// ============================================================
$method = $_SERVER['REQUEST_METHOD'];
$action = $_GET['action'] ?? '';
$body   = json_decode(file_get_contents('php://input'), true) ?? [];

switch($action){

    // ---- الفواتير ----
    case 'get_invoices':
        echo json_encode(['ok'=>true, 'data'=> db_get('invoices_list', [])]);
        break;

    case 'save_invoice':
        $invoices = db_get('invoices_list', []);
        $inv = sanitize_data($body);
        if(empty($inv['id'])) $inv['id'] = 'inv-' . time() . '-' . rand(100,999);
        // تحديث إذا موجود، إضافة إذا جديد
        $found = false;
        foreach($invoices as &$existing){
            if($existing['id'] === $inv['id']){
                $existing = $inv;
                $found = true;
                break;
            }
        }
        if(!$found) array_unshift($invoices, $inv);
        db_set('invoices_list', $invoices);
        echo json_encode(['ok'=>true, 'id'=>$inv['id']]);
        break;

    case 'delete_invoice':
        $id = sanitize_text_field($body['id'] ?? '');
        $invoices = db_get('invoices_list', []);
        $invoices = array_values(array_filter($invoices, fn($i) => $i['id'] !== $id));
        db_set('invoices_list', $invoices);
        echo json_encode(['ok'=>true]);
