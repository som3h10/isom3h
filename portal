    // ---- النماذج ----
    case 'get_templates':
        // النماذج كبيرة (صور) — نرجع الـ metadata فقط بدون bgDataUrl
        $templates = db_get('templates_map', []);
        $meta = [];
        foreach($templates as $id => $t){
            $meta[$id] = array_diff_key($t, ['bgDataUrl'=>1, 'termsBgDataUrl'=>1]);
            $meta[$id]['hasBg']    = !empty($t['bgDataUrl']);
            $meta[$id]['hasTerms'] = !empty($t['termsBgDataUrl']);
        }
        echo json_encode(['ok'=>true, 'data'=>$meta]);
        break;

    case 'get_template':
        $id = sanitize_text_field($_GET['id'] ?? '');
        $templates = db_get('templates_map', []);
        if(isset($templates[$id])){
            echo json_encode(['ok'=>true, 'data'=>$templates[$id]]);
        } else {
            echo json_encode(['ok'=>false, 'error'=>'Not found']);
        }
        break;

    case 'save_template':
        $templates = db_get('templates_map', []);
        $tpl = sanitize_data($body);
        if(empty($tpl['id'])) $tpl['id'] = 'tpl-' . time();
        $templates[$tpl['id']] = $tpl;
        db_set('templates_map', $templates);
        echo json_encode(['ok'=>true, 'id'=>$tpl['id']]);
        break;

    case 'delete_template':
        $id = sanitize_text_field($body['id'] ?? '');
        $templates = db_get('templates_map', []);
        unset($templates[$id]);
        db_set('templates_map', $templates);
        // حذف النموذج النشط إذا كان هو
        $active = db_get('active_template', '');
        if($active === $id) db_set('active_template', '');
        echo json_encode(['ok'=>true]);
