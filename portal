    default:
        http_response_code(400);
        echo json_encode(['error'=>'Unknown action: '.$action]);
}

// ============================================================
// Helper functions
// ============================================================
function db_get(string $key, $default = null){
    $val = get_option('inv_app_' . $key, null);
    if($val === null || $val === false) return $default;
    $decoded = json_decode($val, true);
    return ($decoded !== null) ? $decoded : $default;
}

function db_set(string $key, $value): bool {
    $encoded = json_encode($value, JSON_UNESCAPED_UNICODE);
    return update_option('inv_app_' . $key, $encoded, false);
}

function sanitize_data($data){
    if(is_array($data)){
        $clean = [];
        foreach($data as $k => $v){
            $clean[sanitize_key_safe($k)] = sanitize_data($v);
        }
        return $clean;
    }
    if(is_string($data)){
        // نحتفظ بـ base64 للصور — لا نغيرها
        if(strlen($data) > 200 && strpos($data, 'data:image') === 0) return $data;
        return wp_kses_post($data);
    }
    return $data;
}

function sanitize_key_safe($k){
    // السماح بالأرقام والحروف والشرطات والنقاط
    return preg_replace('/[^a-zA-Z0-9_\-\.]/', '', $k);
}

